# Flowers Crawler 环境变量示例
# ----------------------------------------------------------------------------
# 复制本文件为 .env 并填入真实值（.env 已在 .gitignore 中被忽略）。
# `make run-pexels` 会自动从此文件加载 Pexels API Key。

# 标准大写（推荐，与 Pexels 官方文档一致）
PEXELS_API_KEY=YOUR_API_KEY

# 兼容小写（备选，等价于上面）
pexels_api_key=YOUR_API_KEY
